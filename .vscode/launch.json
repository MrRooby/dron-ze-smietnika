{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build STM8",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/main.ihx",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build_and_upload",
            "miDebuggerPath": "/usr/bin/stm8-gdb"
        }
    ],
    "tasks": [
        {
            "label": "build_and_upload",
            "type": "shell",
            "command": "make",
            "args": ["upload"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "build",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"]
        }
    ]
}